build/
build.*/
build.new/
build.test/
build.prev*/
bin/
obj/
**/bin/
**/obj/

# Native build outputs
src/Native/libxelishashv3/build/
external/xelis-hash/C/build/

# Runtime configs and secrets
config.json
*.wallet
*.wallet.*
*.keys
.rpcpass
.rpcuser
.wallet_pass
.wallet_rpc_pass
.api_key

# Runtime files
*.log
*.sql
*.dump
mbck/
dag-zano/
**/dag-zano/

# Archives / temporary files
*.tar.gz
*.zip
*.bak
